{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "python .claude/hooks/session_start.py" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "python .claude/hooks/guard_vault_write.py" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "python .claude/hooks/capture_pytest.py" }]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [{ "type": "command", "command": "python .claude/hooks/subagent_done.py" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "python .claude/hooks/stop_gate.py" }]
      }
    ]
  }
}
